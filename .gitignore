# Sensitive files
.env
.env.*
*.key
*.pem
credentials.*
secrets.*

# API keys and config that may contain them
**/api_key*
**/apikey*
**/*secret*
**/*token*

# baoyu-skills runtime config (may contain API keys)
.baoyu-skills/.env
.baoyu-skills/**/EXTEND.md

# User learning data (personal, not for sharing)
# Phase 1 outputs
domains/*/skeleton.md
domains/*/researchers.md
domains/*/curriculum.md
domains/*/sources.md
domains/*/meta.md
# Phase 2 outputs
domains/*/papers/
domains/*/concepts/
domains/*/modules/
# Phase 4 outputs
domains/*/learning-path.md
domains/*/cheatsheet*.md
# Phase 3 outputs
domains/*/qa/
# Phase 5 outputs
domains/*/published/
domains/*/assets/
# Misc
domains/*/*.py
domains/*/*.docx

# Design docs (local only)
docs/

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

# Build artifacts (minimax-docx .NET)
**/bin/
**/obj/
*.user

# Playwright MCP logs
.playwright-mcp/

# Python
__pycache__/
*.pyc
*.pyo

# Infographic intermediate files (regeneratable)
**/infographic/**/generate_infographic.py
**/infographic/**/infographic.html

# Memory (user-specific, not for sharing)
.claude/projects/

# Generated XHS images (local output, not for sharing)
xhs-images/
